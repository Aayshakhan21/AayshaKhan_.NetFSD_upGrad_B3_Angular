{
  "info": {
    "name": "ShopEZ API",
    "description": "ShopEZ E-Commerce REST API — ASP.NET Core 8 + JWT Auth\n\nSetup:\n1. Set the `baseUrl` variable to https://localhost:60466\n2. Run 'Login as Admin' or 'Login as Customer' — the token is saved automatically to adminToken / customerToken\n3. All protected requests use those variables via Bearer Token auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:60466", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "customerToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Jane@1234\",\n  \"role\": \"Customer\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('adminToken', json.data.token);",
                  "    console.log('Admin token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopez.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login as Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('customerToken', json.data.token);",
                  "    console.log('Customer token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aaysha.khan@example.com\",\n  \"password\": \"Aaysha@123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login — Wrong Password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopez.com\",\n  \"password\": \"WrongPassword\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (Public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          },
          "response": []
        },
        {
          "name": "Get Product by ID (Public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/1", "host": ["{{baseUrl}}"], "path": ["api", "products", "1"] }
          },
          "response": []
        },
        {
          "name": "Get Product — Not Found (404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/999", "host": ["{{baseUrl}}"], "path": ["api", "products", "999"] }
          },
          "response": []
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Stand\",\n  \"description\": \"Ergonomic aluminium stand for laptops up to 17 inch.\",\n  \"price\": 1499.99,\n  \"imageUrl\": \"https://example.com/images/laptopstand.jpg\",\n  \"stock\": 60\n}"
            }
          },
          "response": []
        },
        {
          "name": "Create Product — Customer Forbidden (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Stand\",\n  \"description\": \"Should be rejected.\",\n  \"price\": 1499.99,\n  \"imageUrl\": \"\",\n  \"stock\": 10\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/products/5", "host": ["{{baseUrl}}"], "path": ["api", "products", "5"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor Stand Pro\",\n  \"description\": \"Heavy-duty monitor stand with cable management.\",\n  \"price\": 1099.99,\n  \"imageUrl\": \"https://example.com/images/monitorstand.jpg\",\n  \"stock\": 35\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/5", "host": ["{{baseUrl}}"], "path": ["api", "products", "5"] }
          },
          "response": []
        },
        {
          "name": "Delete Product — Has Orders, Restricted (409/500)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/products/1", "host": ["{{baseUrl}}"], "path": ["api", "products", "1"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order (Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartItems\": [\n    { \"productId\": 2, \"quantity\": 1 },\n    { \"productId\": 3, \"quantity\": 2 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Place Order — Insufficient Stock (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartItems\": [\n    { \"productId\": 4, \"quantity\": 9999 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Place Order — Invalid Product (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartItems\": [\n    { \"productId\": 999, \"quantity\": 1 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          },
          "response": []
        },
        {
          "name": "Get All Orders — Customer Forbidden (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          },
          "response": []
        },
        {
          "name": "Get Order by ID (Admin — any)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/1", "host": ["{{baseUrl}}"], "path": ["api", "orders", "1"] }
          },
          "response": []
        },
        {
          "name": "Get Order by ID (Customer — own)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/1", "host": ["{{baseUrl}}"], "path": ["api", "orders", "1"] }
          },
          "response": []
        },
        {
          "name": "Get Orders by User (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/user/2", "host": ["{{baseUrl}}"], "path": ["api", "orders", "user", "2"] }
          },
          "response": []
        },
        {
          "name": "Get Orders by User — No Orders (Empty Array)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/user/3", "host": ["{{baseUrl}}"], "path": ["api", "orders", "user", "3"] }
          },
          "response": []
        }
      ]
    }
  ]
}
